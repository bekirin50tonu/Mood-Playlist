# ── Spotify (https://developer.spotify.com/dashboard) ──────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Where Spotify sends the user after they authorize. Must match the
# "Redirect URI" registered in your Spotify app dashboard exactly.
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ── Gemini (https://aistudio.google.com/apikey) ─────────────────────────────
GEMINI_API_KEY=

# ── Session signing ──────────────────────────────────────────────────────────
# Random 32+ char string. Used to sign the auth cookie.
SESSION_SECRET=change-me-to-a-long-random-string

# ── Public (exposed to browser) ─────────────────────────────────────────────
# Where the browser redirects back to after Spotify auth. Must be the same
# host the user is on in dev.
NEXT_PUBLIC_REDIRECT_BASE=http://localhost:3000
